@page "/network"
@inject Nas.Ui.Client.Services.NasApiService Api

<PageTitle>NAS - Network</PageTitle>

<h4 class="mb-3">Network Proxy Status</h4>

@if (_loading)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else if (_error)
{
    <div class="alert alert-warning">Unable to connect to NAS backend.</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Active Sessions</h6>
                    <p class="card-text display-6">@(_sessions?.Count ?? 0)</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Pending Requests</h6>
                    <p class="card-text display-6">@_pendingCount</p>
                </div>
            </div>
        </div>
    </div>

    <h5>Network Sessions</h5>
    @if (_sessions is { Count: > 0 })
    {
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>Session ID</th>
                    <th>Agent</th>
                    <th>Profile</th>
                    <th>Started</th>
                    <th>Pending</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _sessions)
                {
                    <tr>
                        <td><code>@s.SessionId</code></td>
                        <td>@(s.AgentType ?? "—")</td>
                        <td>@(s.ProfileName ?? "—")</td>
                        <td>@(s.StartedAt ?? "—")</td>
                        <td>
                            @{
                                var pending = _pendingBySession.GetValueOrDefault(s.SessionId);
                            }
                            @if (pending is { Count: > 0 })
                            {
                                <span class="badge bg-warning">@pending.Count</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">0</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-secondary">No active network sessions.</div>
    }

    @if (_pendingBySession.Count > 0)
    {
        <h5 class="mt-4">Pending Requests</h5>
        @foreach (var (sessionId, entries) in _pendingBySession)
        {
            <h6>Session: <code>@sessionId</code></h6>
            <table class="table table-sm table-bordered">
                <thead>
                    <tr><th>Domain</th><th>Timestamp</th></tr>
                </thead>
                <tbody>
                    @foreach (var e in entries)
                    {
                        <tr><td>@e.Domain</td><td>@e.Timestamp</td></tr>
                    }
                </tbody>
            </table>
        }
    }
}

@code {
    private bool _loading = true;
    private bool _error;
    private List<Services.SessionEntry>? _sessions;
    private int _pendingCount;
    private Dictionary<string, List<Services.PendingEntry>> _pendingBySession = new();

    protected override async Task OnInitializedAsync()
    {
        var sessions = await Api.GetSessionsAsync();
        var pending = await Api.GetPendingAsync();

        if (sessions is null)
        {
            _error = true;
        }
        else
        {
            _sessions = sessions.Network;
            if (pending?.Network is not null)
            {
                foreach (var g in pending.Network)
                {
                    _pendingBySession[g.SessionId] = g.Entries;
                }
                _pendingCount = pending.Network.Sum(g => g.Entries.Count);
            }
        }

        _loading = false;
    }
}
