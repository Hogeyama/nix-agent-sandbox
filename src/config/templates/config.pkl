amends "modulepath:/global.pkl"

// To amend the schema directly instead of inheriting from global.pkl,
// replace the line above with:
//   amends "Schema.pkl"

// Mask secrets from the agent (any file-read path shows same-length "*"):
//   ["default"] {
//     mask = new MaskConfig {
//       values { new { source = "dotenv:.env#DB_PASSWORD" } }
//     }
//   }

profiles {
  ["default"] {
    agent = "claude"
  }
}
