#!/bin/sh
set -e

if ! command -v deno >/dev/null 2>&1; then
  echo "Error: deno not found. Run 'nix develop' first, or use 'nix develop -c git commit ...'"
  exit 1
fi

echo "Running deno fmt..."
deno fmt --check

echo "Running deno lint..."
deno lint

echo "Running deno test..."
deno test --allow-all
