{
  "name": "nas",
  "version": "0.1.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-all main.ts",
    "build-ui": "deno run -A scripts/build_ui.ts",
    "compile": "deno compile --allow-all --include src/docker/embed/ --include src/docker/envoy/ --include src/ui/dist/ --include scripts/notify-send-wsl --output nas main.ts",
    "test": "deno test --allow-all src/ tests/",
    "test:unit": "deno test $(find src -name '*_test.ts' ! -name '*_integration_test.ts')",
    "test:integration": "deno test --allow-all src/ tests/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check main.ts",
    "hostexec-demo": "deno run --allow-env --allow-read --allow-write scripts/hostexec_demo.ts"
  },
  "lint": {
    "exclude": [
      "src/ui/frontend/",
      "src/ui/dist/",
      "src/docker/embed/local-proxy.mjs"
    ]
  },
  "fmt": {
    "exclude": ["**/*.md", "src/ui/frontend/", "src/ui/dist/"]
  },
  "imports": {
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "dax": "https://deno.land/x/dax@0.39.2/mod.ts",
    "hono": "jsr:@hono/hono",
    "esbuild": "npm:esbuild@0.24",
    "esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@0.11",
    "preact": "https://esm.sh/preact@10",
    "preact/": "https://esm.sh/preact@10/",
    "zod": "npm:zod@3.24.4"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "https://esm.sh/preact@10"
  }
}
