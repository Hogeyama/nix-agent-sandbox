{
  "name": "nas",
  "version": "0.8.1",
  "type": "module",
  "module": "main.ts",
  "scripts": {
    "dev": "bun run main.ts",
    "build-ui": "bun run scripts/build_ui.ts",
    "compile": "bun build --compile --outfile nas main.ts",
    "test": "bun test src/ tests/",
    "test:unit": "bash -c 'bun test $(find src -name \"*_test.ts\" ! -name \"*_integration_test.ts\")'",
    "test:integration": "bash -c 'bun test $(find src tests -name \"*_integration_test.ts\") tests/'",
    "lint": "biome check src/ tests/ scripts/ main.ts",
    "fmt": "biome format --write src/ tests/ scripts/ main.ts",
    "check": "tsc --noEmit",
    "bun2nix": "bun2nix -o bun.nix"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "effect": "^3.21.0",
    "preact": "^10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@playwright/cli": "^0.1.8",
    "@types/node": "^22",
    "bun-types": "latest",
    "bun2nix": "latest",
    "typescript": "^6.0.2"
  }
}
