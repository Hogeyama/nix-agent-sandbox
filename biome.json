{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"indentStyle": "space",
		"indentWidth": 2
	},
	"overrides": [
		{
			"includes": [
				"src/**/*_test.ts",
				"src/**/*_integration_test.ts",
				"tests/**/*.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
